// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Role {
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
  STAFF
}

// Appointment status
enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// User model for authentication
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  email     String?
  role      Role     @default(STAFF)
  avatar    String?
  active    Boolean  @default(true)
  
  // Relations
  doctor    Doctor?
  nurse     Nurse?
  staff     Staff?
  messages  Message[]
  messageReceipts MessageReceipt[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([username])
  @@index([role])
}

// Doctor model
model Doctor {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialization  String
  licenseNumber   String   @unique
  department      String
  phone           String?
  
  // Relations
  medicalRecords  MedicalRecord[]
  appointments    Appointment[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
  @@index([department])
}

// Nurse model
model Nurse {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  department      String
  licenseNumber   String   @unique
  phone           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
  @@index([department])
}

// General Staff model
model Staff {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  position        String
  department      String
  phone           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
  @@index([department])
}

// Patient model
model Patient {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String   @unique
  phone           String
  dateOfBirth     DateTime
  gender          String
  bloodType       String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  emergencyContact String?
  
  // Relations
  medicalRecords  MedicalRecord[]
  appointments    Appointment[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([email])
  @@index([phone])
}

// Medical Record model
model MedicalRecord {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId        String
  doctor          Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  
  diagnosis       String
  prescription    String?
  notes           String?
  recordDate      DateTime
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([patientId])
  @@index([doctorId])
  @@index([recordDate])
}

// Appointment model
model Appointment {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId        String
  doctor          Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  
  appointmentDate DateTime
  status          AppointmentStatus @default(SCHEDULED)
  reason          String?
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentDate])
  @@index([status])
}

// Message model
model Message {
  id              String   @id @default(cuid())
  senderId        String
  sender          User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  content         String
  recipientType   String   @default("ALL") // ALL, PATIENTS, STAFF, SPECIFIC
  recipientRole   Role?
  
  // Relations
  receipts        MessageReceipt[]
  
  createdAt       DateTime @default(now())
  
  @@index([senderId])
  @@index([createdAt])
}

// Message Receipt model for tracking read status
model MessageReceipt {
  id              String   @id @default(cuid())
  messageId       String
  message         Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  readAt          DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([messageId, userId])
  @@index([userId])
  @@index([readAt])
}

// Personal data (e.g. guarantors, emergency contacts, non-patient records)
model PersonalData {
  id          String   @id @default(cuid())
  fullName    String
  email       String?
  phone       String?
  idType      String?  // e.g. National ID, Passport
  idNumber    String?
  dateOfBirth DateTime?
  address     String?
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([fullName])
  @@index([email])
  @@index([phone])
}
